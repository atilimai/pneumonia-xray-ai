# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files — dataset must not be committed
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Artifacts — generated outputs should not be committed
artifacts/checkpoints/*
artifacts/logs/*
artifacts/figures/*
artifacts/reports/*
!artifacts/checkpoints/.gitkeep
!artifacts/logs/.gitkeep
!artifacts/figures/.gitkeep
!artifacts/reports/.gitkeep

# Model weights
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.h5

# Logs
*.log
logs/
runs/
wandb/
mlruns/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Coverage
.coverage
htmlcov/
.pytest_cache/

# MyPy
.mypy_cache/

# Ruff / Black
.ruff_cache/
